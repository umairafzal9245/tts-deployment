# SGLang-Omni Qwen3-TTS 0.6B deployment environment variables
# Copy this file to .env and adjust values for your environment.
#
# Defaults below are tuned for NVIDIA L40S (48 GB GDDR6).
# For smaller GPUs (8-24 GB), reduce MAX_RUNNING_REQUESTS and MEM_FRACTION_STATIC.

# ---------------------------------------------------------------------------
# Model configuration
# ---------------------------------------------------------------------------
SGLANG_OMNI_MODEL_PATH=Qwen/Qwen3-TTS-12Hz-0.6B-Base
SGLANG_OMNI_CONFIG=/app/config/qwen3_tts_0_6b.yaml

# ---------------------------------------------------------------------------
# Server binding
# ---------------------------------------------------------------------------
SGLANG_OMNI_HOST=0.0.0.0
SGLANG_OMNI_PORT=8000
SGLANG_OMNI_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# AR engine tuning
# ---------------------------------------------------------------------------
# Max concurrent AR generation requests (hard cap for simultaneous streams).
# The 0.6B model is memory-bound, so per-step latency is nearly flat up to
# batch 100+ on L40S. The real bottleneck is the vocoder (see below).
#   L40S 48GB:  100  (recommended)
#   A100 40GB:  64
#   A10  24GB:  32
#   T4   16GB:  16
SGLANG_OMNI_MAX_RUNNING_REQUESTS=100

# CUDA graph max batch size. Must be >= MAX_RUNNING_REQUESTS.
# SGLang captures graphs at buckets [1,2,4,8,12,16,32,64,128].
SGLANG_OMNI_CUDA_GRAPH_MAX_BS=128

# Fraction of GPU memory for SGLang static pool (weights + KV cache).
#   L40S 48GB:  0.88
#   24GB GPUs:  0.85
#   16GB GPUs:  0.80
SGLANG_OMNI_MEM_FRACTION_STATIC=0.88

# Max items per /v1/audio/speech/batch request.
SGLANG_OMNI_TTS_BATCH_MAX_ITEMS=32

# ---------------------------------------------------------------------------
# Vocoder tuning (CRITICAL for high concurrency)
# ---------------------------------------------------------------------------
# The Qwen3-TTS vocoder defaults to max_batch_size=8. When many requests
# finish AR simultaneously, they queue in batches of 8, adding significant
# delay. Raising to 64 eliminates this bottleneck.
#   L40S / A100: 64
#   24GB GPUs:   32
#   16GB GPUs:   16
SGLANG_OMNI_VOCODER_MAX_BATCH_SIZE=64
SGLANG_OMNI_VOCODER_MAX_BATCH_WAIT_MS=5

SGLANG_OMNI_STARTUP_TIMEOUT=600

# ---------------------------------------------------------------------------
# Reference audio domain allowlist (empty = allow all public domains)
# ---------------------------------------------------------------------------
# Comma-separated, e.g. SGLANG_OMNI_ALLOWED_MEDIA_DOMAIN=huggingface.co,cdn.example.com
SGLANG_OMNI_ALLOWED_MEDIA_DOMAIN=

# ---------------------------------------------------------------------------
# Hugging Face access (required for private/gated models)
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# Warmup
# ---------------------------------------------------------------------------
SGLANG_OMNI_WARMUP_ENABLED=1
SGLANG_OMNI_WARMUP_TIMEOUT=300

# ---------------------------------------------------------------------------
# Graceful shutdown timeout (seconds)
# ---------------------------------------------------------------------------
SGLANG_OMNI_GRACEFUL_TIMEOUT=60

# ---------------------------------------------------------------------------
# Container resource limits (CPU/RAM on the host)
# ---------------------------------------------------------------------------
SGLANG_OMNI_CPU_LIMIT=16
SGLANG_OMNI_MEMORY_LIMIT=64G
