# =============================================================================
# SGLang-Omni Qwen3-TTS 0.6B — Production Environment (NVIDIA L40S 48GB)
# =============================================================================
# Target GPU: NVIDIA L40S (48 GB GDDR6, Ada Lovelace SM89, 768 GB/s)
# Model:      Qwen/Qwen3-TTS-12Hz-0.6B-Base (~1.2 GB weights, bfloat16)
#
# Memory budget on L40S:
#   Total VRAM .............. 48.0 GB
#   Model weights ........... ~1.2 GB
#   mem_fraction_static=0.88 -> 42.2 GB static pool (weights + KV cache)
#   Remaining for activations ~5.8 GB (vocoder + preprocessing + CUDA graphs)
#
# Why 100 concurrent works on L40S:
#   The 0.6B model is MEMORY-BOUND (1.2 GB weights / 768 GB/s = 1.56 ms/step).
#   Per-step compute adds only 3.3µs × batch_size. So batch 100 takes
#   ~3.9 ms/step vs 3.56 ms/step for batch 1 — only 9% slower.
#   The real bottleneck was the VOCODER (default max_batch_size=8), which
#   we override to 64. Without this fix, 100 users would see 260ms vocoder
#   queue delay; with it, only 60ms (2 batches × 30ms).
# =============================================================================

# ---------------------------------------------------------------------------
# Model configuration
# ---------------------------------------------------------------------------
SGLANG_OMNI_MODEL_PATH=fishaudio/s2-pro
SGLANG_OMNI_CONFIG=/app/config/s2pro_tts.yaml

# ---------------------------------------------------------------------------
# Server binding
# ---------------------------------------------------------------------------
SGLANG_OMNI_HOST=0.0.0.0
SGLANG_OMNI_PORT=8000
SGLANG_OMNI_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# SGLang AR engine tuning (L40S-optimized)
# ---------------------------------------------------------------------------
# Max concurrent AR generation requests. Must be <= torch_compile_max_bs
# (default 32 for Qwen3-TTS) and <= cuda_graph_max_bs. The Qwen3-TTS engine
# enables torch.compile by default with torch_compile_max_bs=32, so 32 is the
# safe ceiling without also raising torch_compile_max_bs (not exposed as a CLI
# flag for this pipeline). 32 concurrent streams is ample for a 0.6B model.
SGLANG_OMNI_MAX_RUNNING_REQUESTS=128

# CUDA graph max batch size. Must be >= max_running_requests. SGLang captures
# graphs at buckets [1,2,4,8,12,16,32,64,128]. Set to 128 so batch 100 falls
# into the 128 bucket (no fallback to eager mode).
SGLANG_OMNI_CUDA_GRAPH_MAX_BS=256

# Fraction of GPU memory for SGLang static pool (weights + KV cache).
# 0.88 leaves ~5.8 GB for vocoder activations and CUDA graph workspace.
SGLANG_OMNI_MEM_FRACTION_STATIC=0.88

# Max items per /v1/audio/speech/batch request.
SGLANG_OMNI_TTS_BATCH_MAX_ITEMS=32

# ---------------------------------------------------------------------------
# Vocoder tuning (CRITICAL for high concurrency)
# ---------------------------------------------------------------------------
# The Qwen3-TTS vocoder (BatchVocoderBase) defaults to max_batch_size=8.
# When 100 requests finish AR simultaneously, they queue in batches of 8,
# adding 260ms delay for the last user. Raising to 64 reduces this to
# 2 batches × 30ms = 60ms — a 4× improvement.
SGLANG_OMNI_VOCODER_MAX_BATCH_SIZE=64
SGLANG_OMNI_VOCODER_MAX_BATCH_WAIT_MS=5

# ---------------------------------------------------------------------------
# Startup timeout
# ---------------------------------------------------------------------------
SGLANG_OMNI_STARTUP_TIMEOUT=600

# ---------------------------------------------------------------------------
# Reference audio domain allowlist
# ---------------------------------------------------------------------------
# Comma-separated list of domains allowed for remote ref_audio URLs.
# Empty = allow all public domains. For production, restrict to your CDN:
# SGLANG_OMNI_ALLOWED_MEDIA_DOMAIN=huggingface.co,your-cdn.example.com
SGLANG_OMNI_ALLOWED_MEDIA_DOMAIN=

# ---------------------------------------------------------------------------
# Hugging Face access (required for private/gated models, helps rate limits)
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# Warmup
# ---------------------------------------------------------------------------
SGLANG_OMNI_WARMUP_ENABLED=1
SGLANG_OMNI_WARMUP_TIMEOUT=300

# ---------------------------------------------------------------------------
# Graceful shutdown timeout (seconds)
# ---------------------------------------------------------------------------
SGLANG_OMNI_GRACEFUL_TIMEOUT=60

# ---------------------------------------------------------------------------
# Container resource limits (CPU/RAM on the host, not GPU)
# ---------------------------------------------------------------------------
SGLANG_OMNI_CPU_LIMIT=16
SGLANG_OMNI_MEMORY_LIMIT=64G
